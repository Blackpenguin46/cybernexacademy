    },
    {
      "url": "https://www.welivesecurity.com/2014/11/14/it-pros-also-guilty-of-risque-selfies-on-mobiles/",
      "type": "rich",
      "title": "IT Pros also guilty of risqué selfies on mobiles",
      "timestamp": "2014-11-14T09:30:08+00:00",
      "thumbnail": {
        "width": 1745,
        "url": "https://bitvision.s3.eu-central-1.amazonaws.com/cybersecurity/bot/welivesecurity.png",
        "proxy_url": "https://images-ext-1.discordapp.net/external/DW4UYn3rBilk3rFCoAPcIhUfGKTeKe80ELpX_-DlGjY/https/bitvision.s3.eu-central-1.amazonaws.com/cybersecurity/bot/welivesecurity.png",
        "placeholder_version": 1,
        "placeholder": "X1WBCYIkjgJ4iEiPePiIh3iHhYhwqJg=",
        "height": 247,
        "flags": 0
      },
      "description": "ESET study reveals many IT professionals are guilty of storing indecent material on their mobile phones, which would leave them embarrassed if lost.",
